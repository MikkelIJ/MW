<Window x:Class="MW.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#88000000"
        Topmost="True" ShowInTaskbar="False" WindowState="Maximized"
        WindowStartupLocation="Manual" Cursor="Cross"
        KeyDown="OnKeyDown" MouseDown="OnMouseDown" MouseMove="OnMouseMove" MouseUp="OnMouseUp">
    <Grid>
        <Canvas x:Name="canvas" Background="Transparent"/>
        <TextBlock VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0"
                   Foreground="White" FontSize="14"
                   Text="Drag to draw regions  •  Click a region to delete  •  Enter to save  •  Esc to cancel"/>
    </Grid>
</Window>
